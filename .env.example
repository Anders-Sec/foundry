# ============================================================
# Foundry — environment variable template
#
# This file IS committed to git. It documents every variable
# the stack reads, with safe defaults for local development.
#
# DO NOT put real secrets in this file — ever.
# DO NOT commit .env — it is gitignored.
#
# To get started:
#   make bootstrap       (copies this file to .env automatically)
#
# Production secrets come from HashiCorp Vault starting Phase 8.
# ============================================================

# === Postgres ===============================================
POSTGRES_USER=foundry
POSTGRES_PASSWORD=foundry-local-dev-only
POSTGRES_DB=foundry
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Backend ================================================
# Set to "development" locally.
FOUNDRY_ENV=development
FOUNDRY_LOG_LEVEL=DEBUG

# 32+ character random string. Regenerate per environment.
# Never reuse the same secret across deployments.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FOUNDRY_JWT_SECRET=change-me-generate-a-real-secret-before-use

# Assembled from the Postgres vars above — usually no need to change locally.
FOUNDRY_DATABASE_URL=postgresql+asyncpg://foundry:foundry-local-dev-only@postgres:5432/foundry

# Required false locally — the frontend runs on http://, not https://.
# Must be true in any deployed environment.
FOUNDRY_COOKIE_SECURE=false

# Seed data password for the local admin user. For local dev only.
# See backend/README.md — never use this in a deployed environment.
FOUNDRY_SEED_ADMIN_PASSWORD=foundry-dev-admin

# === Frontend ===============================================
# VITE_* prefixed variables are bundled into the browser-side JavaScript.
# Do NOT place secrets, tokens, or backend credentials in VITE_* variables.
VITE_API_BASE_URL=http://localhost:8000
