FROM python:3.12.8-slim

WORKDIR /app

# Install build dependencies needed for asyncpg and argon2-cffi compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
  && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.5.18 /uv /usr/local/bin/uv

# Install dependencies first (cached layer — invalidated only when pyproject.toml or uv.lock changes)
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen --no-install-project

# Copy source (overridden by bind mount in Compose, but needed for standalone image use)
COPY . .

# Run as non-root
RUN useradd --create-home --shell /bin/bash appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

# CMD is provided by compose.yaml (uvicorn with --reload)
